{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"CURRENT_TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "H=\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-git-safety.sh\"; [ -x \"$H\" ] && exec \"$H\"; exit 0"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "H=\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-skill-contract.sh\"; [ -x \"$H\" ] && exec \"$H\"; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "H=\"$CLAUDE_PROJECT_DIR/.claude/hooks/observe-skill.sh\"; [ -x \"$H\" ] && exec \"$H\"; exit 0"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "H=\"$CLAUDE_PROJECT_DIR/.claude/hooks/heartbeat.sh\"; [ -x \"$H\" ] && exec \"$H\"; exit 0"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "H=\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\"; [ -x \"$H\" ] && exec \"$H\"; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "H=\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-end.sh\"; [ -x \"$H\" ] && exec \"$H\"; exit 0"
          }
        ]
      }
    ]
  },
  "search": {
    "backend": "hybrid",
    "embedding_provider": "fastembed",
    "embedding_model": "all-MiniLM-L6-v2",
    "weights": [
      0.4,
      0.6
    ],
    "chunk_max_chars": 2000
  }
}
